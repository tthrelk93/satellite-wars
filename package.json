{
  "name": "satellite-wars",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "three": "^0.165.0",
    "three-orbitcontrols": "^2.110.3",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "node scripts/dev.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "agent:cycle-streak": "node scripts/agent/summarize-cycle-streak.mjs",
    "agent:dev-server": "node scripts/agent/dev-server.mjs",
    "agent:orographic-audit": "node --experimental-default-type=module --loader ./scripts/agent/resolve-js-loader.mjs scripts/agent/orographic-audit.mjs",
    "agent:orographic-probe-cdp": "node scripts/agent/orographic-probe-cdp.mjs",
    "agent:reuse-localhost-tab": "node scripts/agent/reuse-localhost-tab.mjs",
    "agent:summarize-runtime-log": "node scripts/agent/summarize-runtime-log.mjs",
    "agent:profile-runtime-hotspots": "node scripts/agent/profile-runtime-hotspots.mjs",
    "weather:check": "node scripts/check-weather-log.mjs",
    "weather:validate": "node scripts/validate-weather-case.mjs",
    "weather:validate:export": "node scripts/export-validation-snapshots.mjs",
    "weather:validate:test": "node --experimental-default-type=module --experimental-specifier-resolution=node --test weather-validation/tests/*.test.mjs src/weather/v2/verticalGrid.test.js src/weather/v2/initializeFromClimo.test.js src/weather/v2/initializeFromAnalysis.test.js src/weather/v2/analysisLoader.test.js src/weather/v2/nudging5.test.js src/weather/v2/windNudge5.test.js src/weather/v2/terrainCoupling.test.js src/weather/v2/oceanIce.test.js src/weather/v2/cloudRadiation.test.js src/weather/v2/microphysicsPhase7.test.js",
    "weather:analysis:convert": "node scripts/convert-weather-analysis.mjs",
    "weather:benchmark": "node scripts/run-weather-benchmark-suite.mjs",
    "verify:no-v1-weather": "node scripts/no-v1-weather.mjs",
    "wind:targets": "node scripts/wind/extractZonalMeanTargets.mjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
