{
  "name": "satellite-wars",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "three": "^0.165.0",
    "three-orbitcontrols": "^2.110.3",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "node scripts/dev.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "agent:cycle-streak": "node scripts/agent/summarize-cycle-streak.mjs",
    "agent:recover-interrupted-cycle": "node scripts/agent/recover-interrupted-cycle.mjs",
    "agent:wake-bootstrap": "node scripts/agent/wake-bootstrap.mjs",
    "agent:start-cycle": "node scripts/agent/start-cycle.mjs",
    "agent:refresh-worker-brief": "node scripts/agent/build-worker-brief.mjs",
    "agent:dev-server": "node scripts/agent/dev-server.mjs",
    "agent:orographic-audit": "node --experimental-default-type=module --loader ./scripts/agent/resolve-js-loader.mjs scripts/agent/orographic-audit.mjs",
    "agent:planetary-realism-audit": "node --experimental-default-type=module --loader ./scripts/agent/resolve-js-loader.mjs scripts/agent/planetary-realism-audit.mjs",
    "agent:annual-physics-targets": "node scripts/agent/annual-physics-targets.mjs",
    "agent:planetary-candidate-sweep": "node --experimental-default-type=module --loader ./scripts/agent/resolve-js-loader.mjs scripts/agent/planetary-candidate-sweep.mjs",
    "agent:minimal-failing-corridor": "node scripts/agent/minimal-failing-corridor.mjs",
    "agent:vertical-handoff-proof": "node scripts/agent/vertical-handoff-proof.mjs",
    "agent:prevertical-boundary-ledger": "node scripts/agent/prevertical-boundary-ledger.mjs",
    "agent:prevertical-provenance-ownership": "node scripts/agent/prevertical-provenance-ownership.mjs",
    "agent:prevertical-supply-vs-retention-counterfactuals": "node scripts/agent/prevertical-supply-vs-retention-counterfactuals.mjs",
    "agent:prevertical-reduced-order-experiments": "node scripts/agent/prevertical-reduced-order-experiments.mjs",
    "agent:prevertical-numerical-ownership-check": "node scripts/agent/prevertical-numerical-ownership-check.mjs",
    "agent:prevertical-numerical-repair-audit": "node scripts/agent/prevertical-numerical-repair-audit.mjs",
    "agent:prevertical-variant-normalized-ownership": "node scripts/agent/prevertical-variant-normalized-ownership.mjs",
    "agent:prevertical-patch-placement-proof": "node scripts/agent/prevertical-patch-placement-proof.mjs",
    "agent:phase1b-exact-corridor-support-proof": "node scripts/agent/phase1b-exact-corridor-support-proof.mjs",
    "agent:orographic-probe-cdp": "node scripts/agent/orographic-probe-cdp.mjs",
    "agent:reuse-localhost-tab": "node scripts/agent/reuse-localhost-tab.mjs",
    "agent:summarize-runtime-log": "node scripts/agent/summarize-runtime-log.mjs",
    "agent:profile-runtime-hotspots": "node scripts/agent/profile-runtime-hotspots.mjs",
    "weather:check": "node scripts/check-weather-log.mjs",
    "weather:validate": "node scripts/validate-weather-case.mjs",
    "weather:validate:export": "node scripts/export-validation-snapshots.mjs",
    "weather:validate:test": "node --experimental-default-type=module --experimental-specifier-resolution=node --test weather-validation/tests/*.test.mjs src/weather/v2/verticalGrid.test.js src/weather/v2/initializeFromClimo.test.js src/weather/v2/initializeFromAnalysis.test.js src/weather/v2/analysisLoader.test.js src/weather/v2/nudging5.test.js src/weather/v2/windNudge5.test.js src/weather/v2/terrainCoupling.test.js src/weather/v2/oceanIce.test.js src/weather/v2/cloudRadiation.test.js src/weather/v2/microphysicsPhase7.test.js",
    "weather:analysis:convert": "node scripts/convert-weather-analysis.mjs",
    "weather:benchmark": "node scripts/run-weather-benchmark-suite.mjs",
    "weather:planetary:audit": "npm run agent:planetary-realism-audit -- --preset quick",
    "weather:planetary:audit:seasonal": "npm run agent:planetary-realism-audit -- --preset seasonal",
    "weather:planetary:audit:annual": "npm run agent:planetary-realism-audit -- --preset annual",
    "weather:planetary:audit:annual:report": "npm run agent:planetary-realism-audit -- --preset annual --report-base weather-validation/output/annual-planetary-realism",
    "weather:planetary:targets:annual": "npm run agent:annual-physics-targets -- --report-base weather-validation/output/annual-planetary-realism",
    "weather:planetary:audit:annual:tuning-pack": "npm run weather:planetary:audit:annual:report && npm run weather:planetary:targets:annual",
    "verify:no-v1-weather": "node scripts/no-v1-weather.mjs",
    "wind:targets": "node scripts/wind/extractZonalMeanTargets.mjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
